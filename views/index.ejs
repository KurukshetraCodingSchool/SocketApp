<%- include('partials/header')%>
<div class="chat-header">💬 Chat App</div>
<div class="conversionArea">
  <div class="messages"></div>
  <div class="inputs">
    <input type="text" placeholder="Type A Message">
    <button>Send</button>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();

const msgBox = document.querySelector('.messages');

function scrollBottom() {
  msgBox.scrollTop = msgBox.scrollHeight;
}

 function incomingMessage(msg) {
    msgBox.innerHTML+=`<div class="msg incomingMessage">${msg}</div>`
    scrollBottom();
  }
  function outgoingMessage(msg) {
    msgBox.innerHTML+=`<div class="msg outgoingMessage">${msg}</div>`
    scrollBottom();

  }
const input = document.querySelector('input');
const button = document.querySelector('button');

function sendMessage(){
  const msg = input.value.trim();
  if (msg !== '') {
    outgoingMessage(msg);
    socket.emit('newmsg', msg);
    input.value = '';
  }
}

button.addEventListener('click', sendMessage);

input.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendMessage();
});

socket.on('incomingMessage', (message) => {
  incomingMessage(message);
});
</script>
<%- include('partials/footer')%>
  
